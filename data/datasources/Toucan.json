{
  "name": "Toucan",
  "kind": "data-pipeline",
  "hf_repo": "Agent-Ark/Toucan-1.5M",
  "config": "SFT",
  "split": "train",
  "sample_fields": [
    "uuid",
    "subset_name",
    "question",
    "target_tools",
    "tools",
    "messages"
  ],
  "mapping": {
    "field_map": [
      {
        "ouro_field": "task_id",
        "source_field": "uuid",
        "note": "使用源 UUID 作为唯一标识"
      },
      {
        "ouro_field": "domain",
        "source_field": "subset_name",
        "note": "例如 'single-turn-original'"
      },
      {
        "ouro_field": "split",
        "source_field": "missing",
        "note": "源无 split 字段，需手动划分"
      },
      {
        "ouro_field": "sample_index",
        "source_field": "missing",
        "note": "源无整数索引，可由读取顺序生成"
      },
      {
        "ouro_field": "messages",
        "source_field": "messages",
        "note": "OpenAI 格式对话，含工具调用，可直接使用"
      },
      {
        "ouro_field": "meta",
        "source_field": "derive",
        "note": "可将 uuid、subset_name、target_tools 等打包为 provenance"
      },
      {
        "ouro_field": "verify",
        "source_field": "missing",
        "note": "无客观可验证的奖励信号，仅有对话流程"
      }
    ],
    "messages_compatible": true,
    "has_verifiable_reward": false,
    "sft_usable": true,
    "verdict": "该数据集适合用做监督微调（SFT）数据，提供多轮工具调用对话示例，但缺乏可验证奖励，不能直接用于 RL 奖励训练。"
  },
  "located_via": "spec"
}